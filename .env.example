# ======================================
# Kopiere diese Datei zu .env.local
# und trage deine echten Werte ein.
# ======================================

# Resend API Key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Absender-E-Mail (muss in Resend verifiziert sein)
# Für Tests ohne eigene Domain: weglassen — verwendet dann onboarding@resend.dev
FROM_EMAIL=noreply@deinedomain.de

# Notion Integration — https://www.notion.so/my-integrations
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx

# Notion Database ID (32 Zeichen aus der DB-URL, vor dem ?v=)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
